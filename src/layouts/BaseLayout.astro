---
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  path: string;              // e.g. "/", "/compare/"
  ogType?: string;
  ogImage?: string;          // absolute or site-relative
  current?: 'why' | 'compare' | 'blog';
}

const {
  title,
  description,
  path,
  ogType = 'website',
  ogImage = '/assets/provenant-social-preview.png',
  current,
} = Astro.props;

const site = Astro.site ?? new URL('https://getprovenant.github.io');
const canonical = new URL(path, site).href;
const ogImageAbs = new URL(ogImage, site).href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta name="theme-color" content="#f4f0e8" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#171b24" media="(prefers-color-scheme: dark)" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="sitemap" href="/sitemap-index.xml" />

    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content="Provenant" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageAbs} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageAbs} />

    <slot name="head" />
  </head>
  <body>
    <header class="site-head">
      <div class="wrap-wide bar">
        <a class="brand" href="/"><img src="/assets/provenant-mark.svg" alt="" width="24" height="24" /> Provenant</a>
        <button class="nav-toggle" type="button" aria-label="Open menu" aria-expanded="false" aria-controls="site-nav">
          <svg viewBox="0 0 16 16" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" aria-hidden="true"><path d="M2 4.5h12M2 8h12M2 11.5h12"></path></svg>
        </button>
        <nav class="nav" id="site-nav">
          <a href="/#why" aria-current={current === 'why' ? 'page' : undefined}>Why</a>
          <a href="/compare/" aria-current={current === 'compare' ? 'page' : undefined}>Compare</a>
          <a href="/blog/" aria-current={current === 'blog' ? 'page' : undefined}>Blog</a>
          <a class="ghlink" href="https://github.com/getprovenant/provenant" aria-label="Provenant on GitHub"><svg viewBox="0 0 16 16" width="16" height="16" fill="currentColor" aria-hidden="true"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"></path></svg> GitHub</a>
        </nav>
      </div>
    </header>

    <slot />

    <footer class="site-foot">
      <div class="wrap-wide">
        <div class="cols">
          <div class="brandcol">
            <a class="brand" href="/"><img src="/assets/provenant-mark.svg" alt="" width="24" height="24" /> Provenant</a>
            <p style="color:var(--ink-soft); font-size:0.92rem; margin:0.6rem 0 0;">
              A fast, source-faithful license, copyright, package, and SBOM scanner. Open source under Apache-2.0.
            </p>
          </div>
          <div>
            <h4>Project</h4>
            <ul>
              <li><a href="https://github.com/getprovenant/provenant">GitHub</a></li>
              <li><a href="https://crates.io/crates/provenant-cli">crates.io</a></li>
              <li><a href="https://github.com/getprovenant/provenant/releases/latest">Releases</a></li>
            </ul>
          </div>
          <div>
            <h4>Learn</h4>
            <ul>
              <li><a href="/compare/">Comparison</a></li>
              <li><a href="/blog/the-provenant-story/">The Provenant Story</a></li>
              <li><a href="/blog/engineering-the-loop/">Engineering the Loop</a></li>
            </ul>
          </div>
        </div>
      </div>
    </footer>

    <script is:inline>
      (() => {
        const btn = document.querySelector('.nav-toggle');
        const nav = document.getElementById('site-nav');
        if (!btn || !nav) return;
        const close = () => { nav.removeAttribute('data-open'); btn.setAttribute('aria-expanded', 'false'); };
        btn.addEventListener('click', () => {
          if (nav.hasAttribute('data-open')) close();
          else { nav.setAttribute('data-open', ''); btn.setAttribute('aria-expanded', 'true'); }
        });
        nav.addEventListener('click', (e) => { if (e.target.closest('a')) close(); });
        document.addEventListener('keydown', (e) => { if (e.key === 'Escape') close(); });
      })();
    </script>
  </body>
</html>
